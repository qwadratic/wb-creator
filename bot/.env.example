# --- required ---
TELEGRAM_TOKEN=                # from @BotFather

# --- LLM selection ---
# On exe.dev VM: leave both blank, LLM_GATEWAY=1 — free Anthropic via 169.254.169.254
# Off-VM: set ANTHROPIC_API_KEY, leave LLM_GATEWAY=0
LLM_GATEWAY=1
ANTHROPIC_API_KEY=

# --- optional ---
ANTHROPIC_MODEL=claude-sonnet-4-6
BOT_DATA_DIR=/home/exedev/wb-data   # uploads + workbooks + per-user state (auto-mkdir)
ALLOWED_TG_IDS=                     # comma-separated TG user IDs; empty = open
LOG_LEVEL=INFO
